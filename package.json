{
  "name": "@praddzy/openzeppelin-v5-safe-imports",
  "version": "0.2.0",
  "description": "Codemod workflow for safe OpenZeppelin Contracts v5 Solidity import migrations",
  "type": "module",
  "scripts": {
    "test": "vitest run && npx codemod@latest workflow validate -w .",
    "test:watch": "vitest",
    "test:unit": "vitest run",
    "workflow:validate": "npx codemod@latest workflow validate -w .",
    "workflow:run": "npx codemod@latest workflow run -w .",
    "codemod": "npx codemod@latest workflow run -w .",
    "evaluate": "node ./scripts/evaluate-repo.js"
  },
  "keywords": [
    "codemod",
    "openzeppelin",
    "solidity",
    "migration"
  ],
  "author": "Pratik Daithankar",
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "vitest": "^2.1.3"
  }
}
